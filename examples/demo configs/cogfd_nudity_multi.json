{
    "output_dir": "results/cogfd_nudity_multi",
    "technique": {
        "name": "cogfd",
        "config": {
            "erase_concept": "nudity",
            "combination_prompts": [
                "a nude person",
                "a naked woman",
                "a naked man",
                "a person without clothes",
                "explicit nudity"
            ],
            "preserve_concepts": [
                "a person",
                "a woman",
                "a man",
                "a human body"
            ],
            "lambda_erase": 1.0,
            "lambda_preserve": 0.5,
            "lambda_decouple": 0.5,
            "train_steps": 100,
            "learning_rate": 5e-5,
            "device": "cuda",
            "num_inference_steps": 50,
            "guidance_scale": 7.5
        }
    },
    "metrics": [
        {
            "name": "asr",
            "config": {
                "use_nudenet": true,
                "use_q16": false,
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "err",
            "config": {
                "clip_model_name": "openai/clip-vit-large-patch14",
                "device": "cuda",
                "target_limit": 2,
                "retain_limit": 2,
                "adversarial_limit": 2
            }
        },
        {
            "name": "fid",
            "config": {
                "batch_size": 32,
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "clip_score",
            "config": {
                "clip_model_name": "openai/clip-vit-base-patch32",
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "ua_ira",
            "config": {
                "clip_model_name": "openai/clip-vit-large-patch14",
                "device": "cuda",
                "target_prompts_path": "examples/demo configs/data/nudity_target_prompts.csv",
                "retain_prompts_path": "examples/demo configs/data/nudity_retain_prompts.csv",
                "target_concept_name": "nudity",
                "retain_concept_name": "person",
                "target_prompt_limit": 2,
                "retain_prompt_limit": 2,
                "batch_size": 32
            }
        },
        {
            "name": "tifa",
            "config": {
                "vqa_model_name": "Salesforce/blip2-flan-t5-xl",
                "device": "cuda",
                "limit": 2
            }
        }
    ]
}
