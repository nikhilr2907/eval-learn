{
    "output_dir": "results/safree_nudity_multi",
    "technique": {
        "name": "safree",
        "config": {
            "erase_concept": "nudity",
            "device": "cuda",
            "alpha": 0.01,
            "enable_svf": true,
            "upperbound_timestep": 10,
            "enable_lra": true,
            "lra_filter_type": "high",
            "freeu_b1": 1.0,
            "freeu_b2": 1.0,
            "freeu_s1": 0.9,
            "freeu_s2": 0.2
        }
    },
    "metrics": [
        {
            "name": "asr",
            "config": {
                "use_nudenet": true,
                "use_q16": false,
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "err",
            "config": {
                "clip_model_name": "openai/clip-vit-large-patch14",
                "device": "cuda",
                "target_limit": 2,
                "retain_limit": 2,
                "adversarial_limit": 2
            }
        },
        {
            "name": "fid",
            "config": {
                "batch_size": 32,
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "clip_score",
            "config": {
                "clip_model_name": "openai/clip-vit-base-patch32",
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "ua_ira",
            "config": {
                "clip_model_name": "openai/clip-vit-large-patch14",
                "device": "cuda",
                "target_prompts_path": "examples/demo configs/data/nudity_target_prompts.csv",
                "retain_prompts_path": "examples/demo configs/data/nudity_retain_prompts.csv",
                "target_concept_name": "nudity",
                "retain_concept_name": "person",
                "target_prompt_limit": 2,
                "retain_prompt_limit": 2,
                "batch_size": 32
            }
        },
        {
            "name": "tifa",
            "config": {
                "vqa_model_name": "Salesforce/blip2-flan-t5-xl",
                "device": "cuda",
                "limit": 2
            }
        },
        {
            "name": "asr_custom",
            "config": {
                "concept_name": "nudity",
                "concept_vector_path": "examples/demo configs/data/Nudity_vector.npy",
                "seed_prompts_csv": "examples/demo configs/data/nudity_target_prompts.csv",
                "generated_prompts_output": "results/safree_nudity_multi/nudity_discovered_prompts.csv",
                "device": "cuda"
            }
        }
    ]
}
