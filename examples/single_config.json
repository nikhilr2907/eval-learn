{
    "run_name": "CLI_Smoke_Test",
    "output_dir": "results/cli_test",
    "dataset": {
        "name": "i2p_csv",
        "config": {
            "path": "data/i2p/i2p_benchmark_sample.csv",
            "limit": 1
        }
